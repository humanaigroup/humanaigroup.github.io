<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Human AI Group · 人与智能系统</title>
  <meta name="description" content="Human AI Group @ Zhejiang University — research on humans and intelligent systems in complex environments.">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23B5121B'/></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Noto+Sans+SC:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/assets/css/homepage.css' | relative_url }}">
</head>
<body>

  <!-- ===== Nav ===== -->
  <nav class="container">
    <div class="site-nav">
      <a href="/" class="nav-logo">
        <span class="seal"></span>
        <div class="nav-logo-text">
          <div class="logo-en">Human AI Group</div>
          <div class="logo-zh">人与智能系统</div>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href="{{ '/research/' | relative_url }}">Research</a></li>
        <li><a href="{{ '/publications/' | relative_url }}">Publications</a></li>
        <li><a href="{{ '/reading/' | relative_url }}">Reading</a></li>
        <li><a href="#">Resources</a></li>
        <li><a href="{{ '/people/' | relative_url }}">People</a></li>
        <li><a href="#join" class="nav-cta">Join us</a></li>
      </ul>
    </div>
  </nav>

  <hr class="divider">

  <!-- ===== 1. Hero ===== -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-main">
          <p class="hero-eyebrow">01 ─── A LAB AT ZHEJIANG UNIVERSITY</p>

          <h1 class="hero-headline zh">智能时代的<br>交互体验<span class="red-period">.</span></h1>

          <p class="hero-subline">Interaction and experience in the age of intelligence.</p>

          <p class="hero-body-zh">在复杂、动态、高风险场景中研究人与智能系统的协同方法，迈向高效、安全、以人为本的人机共生。</p>

          <p class="hero-body-en">We study how humans and AI systems collaborate in complex, dynamic, and high-stakes environments — toward efficient, safe, and human-centered symbiosis.</p>

          <div class="hero-ctas">
            <a href="{{ '/research/' | relative_url }}" class="btn-primary">Explore research →</a>
            <a href="{{ '/publications/' | relative_url }}" class="secondary-link">Selected publications →</a>
          </div>
        </div>

        <aside class="hero-sidebar">
          <div class="hero-sidebar-label">RECENT · 近期</div>
          {% for item in site.data.news limit:4 %}
          <div class="recent-item">
            <div class="recent-meta">{{ item.date | date: "%b %-d" | upcase }} · {{ item.type }} · {{ item.label }}</div>
            <div class="recent-title">{{ item.title }}</div>
            {% if item.sub != "" %}<div class="recent-sub">{{ item.sub }}</div>{% endif %}
          </div>
          {% endfor %}
          <div class="hero-sidebar-footer">
            <a href="#" class="link-cta">View all activity →</a>
          </div>
        </aside>
      </div>

      <div class="hero-photo-strip">
        <img src="{{ '/assets/img/hero_photo.jpg' | relative_url }}" alt="Lab members working at computers in the Human AI Group lab">
        <div class="hero-photo-caption">
          <div class="caption-label">CURRENTLY · 现场</div>
          <div class="caption-text">Lab members at work · 实验室日常</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. Research areas ===== -->
  <section class="section-research">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">02 ─── SECTION</div>
        <div class="header-row" style="margin-top: 16px;">
          <h2 class="section-title">Research areas · <span class="zh">研究方向</span></h2>
          <a href="{{ '/research/' | relative_url }}" class="link-cta">View research →</a>
        </div>
        <p class="tagline">What we work on, in three connected directions.</p>
        <p class="tagline-zh zh">三个相互连接的研究方向。</p>
      </div>

      <hr class="divider">

      <div class="research-grid">
        <div class="research-card">
          <div class="card-number">01</div>
          <div class="card-title">Collaborative<br>Perception</div>
          <div class="card-title-zh zh">协同感知</div>
          <p class="card-desc">Humans and AI sensing the world together — in autonomous driving and aviation.</p>
          <p class="card-desc-zh zh">人与 AI 共同感知世界——面向自动驾驶与航空。</p>
          <div class="card-divider"></div>
          <div class="recent-work-label">RECENT WORK</div>
          <div class="recent-work-title">Visionary Co-Driver →</div>
          <div class="recent-work-venue">IEEE T-ITS · 2025</div>
        </div>

        <div class="research-card">
          <div class="card-number">02</div>
          <div class="card-title">Human-AI<br>Experience</div>
          <div class="card-title-zh zh">人机体验</div>
          <p class="card-desc">Experience as a computable object — modeling both human and AI sides.</p>
          <p class="card-desc-zh zh">把体验作为可计算的对象——人的体验、AI 的体验。</p>
          <div class="card-divider"></div>
          <div class="recent-work-label">RECENT WORK</div>
          <div class="recent-work-title">SimUser →</div>
          <div class="recent-work-venue">CHI · 2024</div>
        </div>

        <div class="research-card">
          <div class="card-number">03</div>
          <div class="card-title">Agentic<br>Hardware</div>
          <div class="card-title-zh zh">智能体硬件</div>
          <p class="card-desc">AI agents in physical hardware — for skill training, healthcare, and rehabilitation.</p>
          <p class="card-desc-zh zh">进入物理世界的 AI agent——技能训练、医疗、康复。</p>
          <div class="card-divider"></div>
          <div class="recent-work-label">RECENT WORK</div>
          <div class="recent-work-title">Hand by Hand →</div>
          <div class="recent-work-venue">IJCAI · 2025</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 3. From the lab ===== -->
  <section class="section-lab section-tinted">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">03 ─── SECTION</div>
        <div class="header-row" style="margin-top: 16px;">
          <h2 class="section-title">From the lab · <span class="zh">来自实验室</span></h2>
          <a href="{{ '/publications/' | relative_url }}" class="link-cta">View all publications →</a>
        </div>
        <p class="tagline">Publications, projects, and updates from the group.</p>
        <p class="tagline-zh zh">实验室发表的论文、项目动态、最近消息。</p>
      </div>

      <hr class="divider">

      <div class="lab-list">
        {% for pub in site.data.publications limit:5 %}
        <div class="lab-row">
          <div>
            <div class="lab-type">{{ pub.type | capitalize }}</div>
            <div class="lab-venue">{{ pub.venue }} · {{ pub.year }}</div>
          </div>
          <div>
            <div class="lab-title">{{ pub.title }}</div>
            <div class="lab-authors">{{ pub.authors | truncatewords: 8 }}</div>
          </div>
          <a href="{{ pub.links.pdf | default: '#' }}" class="lab-cta">Read →</a>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- ===== 4. Notes ===== -->
  <section class="section-notes">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">04 ─── SECTION</div>
        <div class="header-row" style="margin-top: 16px;">
          <h2 class="section-title">Notes · <span class="zh">札记</span></h2>
          <a href="{{ '/reading/' | relative_url }}" class="link-cta">View all notes →</a>
        </div>
        <p class="tagline">Papers students in the group think are worth reading and writing about.</p>
        <p class="tagline-zh zh">学生们读到、想清楚、写下来的札记。</p>
      </div>

      <hr class="divider">

      <div class="notes-grid">
        {% assign featured_note = site.data.notes | where: "featured", true | first %}
        {% if featured_note %}
        <div class="note-featured">
          <div class="note-label">
            <span class="seal seal--small"></span>
            <span class="note-label-text">FEATURED · 精读</span>
            <span class="note-date">{{ featured_note.date | date: "%b %-d, %Y" | upcase }}</span>
          </div>
          <div class="note-paper-title">{{ featured_note.paper }}</div>
          <div class="note-paper-meta">{{ featured_note.paper_meta }}</div>
          <div class="note-card-divider"></div>
          <div class="note-title-zh">{{ featured_note.title_zh }}</div>
          {% if featured_note.subtitle_zh != "" %}<div class="note-subtitle zh">{{ featured_note.subtitle_zh }}</div>{% endif %}
          <blockquote class="note-quote">{{ featured_note.quote }}</blockquote>
          <div class="note-footer">
            <span class="note-author">— {{ featured_note.author }}</span>
            <a href="{{ featured_note.url }}" class="note-read">Read full note ({{ featured_note.word_count }} 字) →</a>
          </div>
        </div>
        {% endif %}

        <div class="notes-side">
          {% assign side_notes = site.data.notes | where: "featured", false %}
          {% for note in side_notes limit:2 %}
          <div class="note-small">
            <div class="note-sm-date">{{ note.date | date: "%b %-d, %Y" | upcase }}</div>
            <div class="note-sm-paper">{{ note.paper }}</div>
            <div class="note-sm-meta">{{ note.paper_meta }}</div>
            <div class="note-sm-divider"></div>
            <div class="note-sm-title zh">{{ note.title_zh }}</div>
            <div class="note-sm-footer">
              <span class="note-sm-author">— {{ note.author }}</span>
              <a href="{{ note.url }}" class="note-sm-read">Read →</a>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 5. Partners ===== -->
  <section class="section-partners section-tinted">
    <div class="container">
      <div class="partners-label eyebrow">PARTNERS · 合作伙伴</div>
      <p class="partners-tagline">Industry and institutional collaborators.</p>
      <div class="partners-row">
        <span>Alibaba</span>
        <span>Huawei</span>
        <span>ByteDance</span>
        <span>XCMG</span>
        <span>NSFC</span>
        <span>National Key R&D Program</span>
      </div>
      <hr class="divider" style="margin-top: 48px;">
    </div>
  </section>

  <!-- ===== 6. Join us ===== -->
  <section class="section-join section-tinted" id="join">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">05 ─── SECTION</div>
        <h2 class="section-title" style="margin-top: 16px;">Join us · <span class="zh">加入我们</span></h2>
      </div>

      <div class="join-grid">
        <div>
          <p class="join-body">We're looking for PhD students, postdocs, and research interns who think hard about how humans and AI work together.</p>
          <p class="join-body-zh zh">我们正在招收对人机交互、人机协同感兴趣的同学。</p>
          <a href="mailto:wxiang@zju.edu.cn" class="btn-primary">Email Wei Xiang →</a>
        </div>

        <div>
          <div class="positions-label">OPEN POSITIONS · 招生信息</div>

          <div class="position">
            <div class="pos-title">PhD students · <span class="zh">博士研究生</span></div>
            <div class="pos-req">Strong potential in HCI, NLP, or human-AI collaboration.</div>
          </div>

          <div class="position">
            <div class="pos-title">Postdocs · <span class="zh">博士后</span></div>
            <div class="pos-req">PhD in HCI, AI, or related fields.</div>
          </div>

          <div class="position">
            <div class="pos-title">Research interns · <span class="zh">科研实习生</span></div>
            <div class="pos-req">Undergrad or master's with relevant experience.</div>
          </div>

          <a href="mailto:wxiang@zju.edu.cn" class="link-cta" style="margin-top: 16px; display: inline-block;">wxiang@zju.edu.cn →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 7. Footer ===== -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-identity">
          <div class="footer-name"><span class="seal seal--logo"></span> Human AI Group</div>
          <div class="footer-name-zh zh">人与智能系统</div>
          <div class="footer-affil">A research lab at Zhejiang University<br>College of Artificial Intelligence</div>
        </div>

        <div class="footer-col">
          <div class="footer-col-label">Address</div>
          <p>Room 303, Yueya Building<br>Zijingang Campus, ZJU</p>
          <p class="zh-line zh">浙大紫金港校区<br>月牙楼 303 室</p>
        </div>

        <div class="footer-col">
          <div class="footer-col-label">Contact</div>
          <a href="mailto:wxiang@zju.edu.cn" class="footer-email">wxiang@zju.edu.cn</a>
          <a href="https://github.com/humanaigroup">GitHub</a>
          <a href="https://scholar.google.com/citations?user=gZAPGI8AAAAJ">Google Scholar</a>
        </div>

        <div class="footer-col">
          <div class="footer-col-label">Explore</div>
          <a href="{{ '/research/' | relative_url }}">Research</a>
          <a href="{{ '/publications/' | relative_url }}">Publications</a>
          <a href="{{ '/reading/' | relative_url }}">Notes · 札记</a>
          <a href="{{ '/people/' | relative_url }}">People</a>
        </div>
      </div>

      <div class="footer-bottom">
        <span>© 2026 Human AI Group · College of Artificial Intelligence, Zhejiang University</span>
        <span>Last updated May 15, 2026</span>
      </div>
    </div>
  </footer>

</body>
</html>
