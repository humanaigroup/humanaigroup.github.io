---
---
<div class="col">
  <div class="card pub-card h-100">
    {% if entry.preview %}
      <div class="card-img-top-wrapper">
        {% if entry.preview contains '://' %}
          <img class="card-img-top" src="{{ entry.preview }}" alt="{{ entry.title }}">
        {% else %}
          {% assign entry_path = entry.preview | prepend: '/assets/img/publication_preview/' %}
          <img class="card-img-top" src="{{ entry_path | relative_url }}" alt="{{ entry.title }}">
        {% endif %}
      </div>
    {% endif %}
    <div class="card-body">
      {% if entry.abbr %}
        <span class="badge pub-badge mb-2">{{ entry.abbr }}</span>
      {% endif %}
      <h5 class="card-title">{{ entry.title }}</h5>
      <p class="card-authors">
        {%- for author in entry.author_array limit: 3 -%}
          {%- if forloop.first == false -%}
            {%- if forloop.last %} and {% else %}, {% endif -%}
          {%- endif -%}
          {{ author.first }} {{ author.last }}
        {%- endfor -%}
        {% assign more = entry.author_array | size | minus: 3 %}
        {% if more > 0 %}, et al.{% endif %}
      </p>
      {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
      <p class="card-venue">
        {% if entry.type == 'article' and entry.journal %}
          <em>{{ entry.journal }}</em>
        {% elsif proceedings contains entry.type and entry.booktitle %}
          <em>{{ entry.booktitle }}</em>
        {% endif %}
        {% if entry.year %} {{ entry.year }}{% endif %}
      </p>
      {% if entry.abstract %}
        <p class="card-abstract">{{ entry.abstract | truncatewords: 30 }}</p>
      {% endif %}
    </div>
    <div class="card-footer bg-transparent">
      <div class="links">
        {% if entry.pdf %}
          {% if entry.pdf contains '://' %}
            <a href="{{ entry.pdf }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
          {% else %}
            <a href="{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
          {% endif %}
        {% endif %}
        {% if entry.arxiv %}
          <a href="http://arxiv.org/abs/{{ entry.arxiv }}" class="btn btn-sm z-depth-0" role="button">arXiv</a>
        {% endif %}
        {% if entry.doi %}
          <a href="https://doi.org/{{ entry.doi }}" class="btn btn-sm z-depth-0" role="button">DOI</a>
        {% endif %}
        {% if entry.code %}
          <a href="{{ entry.code }}" class="btn btn-sm z-depth-0" role="button">Code</a>
        {% endif %}
        {% if entry.video %}
          <a href="{{ entry.video }}" class="btn btn-sm z-depth-0" role="button">Video</a>
        {% endif %}
        {% if entry.html %}
          {% if entry.html contains '://' %}
            <a href="{{ entry.html }}" class="btn btn-sm z-depth-0" role="button">HTML</a>
          {% else %}
            <a href="{{ entry.html | prepend: '/assets/html/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">HTML</a>
          {% endif %}
        {% endif %}
        {% if entry.website %}
          <a href="{{ entry.website }}" class="btn btn-sm z-depth-0" role="button">Website</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>
